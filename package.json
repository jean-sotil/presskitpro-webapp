{
  "name": "presskitpro-webapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.9.0 || >=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "contrast:check": "tsx scripts/contrast-check.ts",
    "analyze": "cross-env ANALYZE=1 NODE_OPTIONS=--no-deprecation next build",
    "bundle:check": "tsx scripts/check-bundle-budget.ts",
    "bundle:update": "tsx scripts/check-bundle-budget.ts --update",
    "lighthouse": "lhci autorun",
    "lighthouse:assert": "lhci assert",
    "generate:grain": "tsx scripts/generate-grain.ts",
    "dev:magic-link": "bun scripts/dev-magic-link.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "payload": "cross-env NODE_OPTIONS='--no-deprecation --conditions=react-server' payload",
    "generate:types": "pnpm payload generate:types",
    "generate:importmap": "pnpm payload generate:importmap",
    "seed": "cross-env NODE_OPTIONS='--no-deprecation --conditions=react-server' tsx --env-file=.env scripts/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lexical/html": "0.41.0",
    "@lexical/link": "0.41.0",
    "@lexical/list": "0.41.0",
    "@lexical/react": "0.41.0",
    "@lexical/rich-text": "0.41.0",
    "@lexical/utils": "0.41.0",
    "@payloadcms/db-postgres": "^3.0.0",
    "@payloadcms/next": "^3.0.0",
    "@payloadcms/richtext-lexical": "^3.0.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.0",
    "@tanstack/react-query": "^5.59.0",
    "clsx": "^2.1.1",
    "graphql": "^16.9.0",
    "lexical": "0.41.0",
    "next": "^15.1.0",
    "next-intl": "^3.26.0",
    "payload": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "sharp": "^0.33.5",
    "stripe": "^22.1.0",
    "supabase": "^2.95.6",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^15.1.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/culori": "^4.0.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "culori": "^4.0.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  }
}
