# =====================================================================
# PressKit Pro — Environment Template
# Copy to `.env` and fill in real values. Never commit `.env`.
#
# Dev runs against a HOSTED Supabase project (no Docker).
# Walk-through: docs/runbooks/dev-hosted-supabase.md
# =====================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Payload CMS ---
# Long random string. Generate with: openssl rand -base64 48
PAYLOAD_SECRET=replace-with-strong-random-string

# --- Postgres ---
# Payload writes to its own `payload` schema (see payload.config.ts).
# Copy the "Direct connection" URI from
#   Supabase dashboard → Project Settings → Database → Connection string.
# Format: postgresql://postgres.<ref>:<pwd>@<region>.pooler.supabase.com:5432/postgres
DATABASE_URI=

# --- Supabase ---
# Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth-sync webhook (task-02) ---
# Shared secret between the auth.users Postgres trigger and the
# /api/webhooks/supabase-auth handler. Must match the value set with:
#   alter database postgres set app.webhook_secret = '<this value>';
SUPABASE_AUTH_WEBHOOK_SECRET=replace-with-strong-random-string

# --- Instagram token encryption (task-08) ---
# AES-256-GCM key (32 bytes, base64). Encrypts InstagramConnections.accessToken
# at rest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotation: mint a new key, decrypt all stored tokens with the old key, and
# re-encrypt under the new key. The ciphertext format is `iv.tag.body`; future
# versions will prefix `v2:` to allow side-by-side decryption during rotation.
INSTAGRAM_TOKEN_ENCRYPTION_KEY=

# --- Contact form: Cloudflare Turnstile (task-14) ---
# Site key is public (rendered into the form widget); secret key is
# server-only and used by the contact-submit route to call siteverify.
# When BOTH are unset the captcha layer is a no-op (logs a warning).
#
# Setup: Cloudflare dashboard → Turnstile → Add site → "Managed" mode.
# In "Hostnames" add every domain that will host the form, one per line:
#   - localhost                         (local dev — Cloudflare allows it)
#   - presskit.pro                      (production)
#   - *.vercel.app                      (Vercel preview deployments, optional)
# Subdomains are NOT auto-included; add them explicitly if you use any.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Instagram embed (task-17) ---
# Optional Facebook app access token. When set, the contact-submit route's
# Instagram embed path uses the Graph oEmbed endpoint (returns a real
# iframe server-side). When unset, the route falls back to building the
# `<blockquote class="instagram-media">` itself — `embed.js` hydrates it
# in the browser. The fallback is the default and works zero-config.
#
# To create one:
#   1. https://developers.facebook.com/apps → register an app.
#   2. Add the "oEmbed Read" permission.
#   3. Generate a long-lived app access token.
INSTAGRAM_OEMBED_ACCESS_TOKEN=

# --- Stripe pricing (task-22 / task-23) ---
# Stripe Price IDs for each tier on the pricing page. The display values
# live alongside these in `lib/pricing/plans.ts`. Task-23 wires the
# checkout flow that consumes the IDs; until then the `/checkout/*`
# routes 404 — the pricing page renders fine without them set.
#
# Stripe dashboard → Products → click product → Pricing → "API ID".
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_ANNUAL=
STRIPE_PRICE_ID_AGENCY=

# --- Contact form: Resend transactional email (task-14) ---
# When unset the contact-submit route logs the would-be message body and
# returns 200 anyway (handy for dev). Set this in production so artists
# actually receive submissions.
# Resend dashboard → API Keys → "Sending access" key.
RESEND_API_KEY=

# Optional override for the From address on contact emails. Leave unset
# in dev to use Resend's free `onboarding@resend.dev` sender (works for
# any account, no DNS setup). Set to e.g. `contact@presskit.pro` once
# the domain is verified in Resend (DNS → SPF/DKIM records).
CONTACT_FROM_EMAIL=

# =====================================================================
# Legacy — local Docker mode (only if you choose to run `supabase start`).
# Not the recommended path. See docs/runbooks/spike-task-02.md.
#
#   DATABASE_URI=postgresql://postgres:postgres@127.0.0.1:54322/postgres
#   NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# =====================================================================
