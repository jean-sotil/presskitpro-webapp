# =====================================================================
# PressKit Pro — Environment Template
# Copy to `.env` and fill in real values. Never commit `.env`.
# Variables introduced by downstream tasks (auth providers, storage,
# email) will be appended here as those tasks land.
# =====================================================================

# --- App ---
# Public origin used for canonical URLs, OG metadata, redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Payload CMS ---
# Long random string. Generate with: openssl rand -base64 48
PAYLOAD_SECRET=replace-with-strong-random-string

# Postgres connection. Local Supabase default port is 54322.
# IMPORTANT: Payload writes to its own `payload` schema. Supabase app
# tables remain in `public`. Schema is configured in payload.config.ts.
DATABASE_URI=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Supabase (consumed by app code in later tasks) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
